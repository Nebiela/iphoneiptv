        ];

        // ==================== ฟังก์ชันหลัก ====================
        function renderChannels() {
            const list = document.getElementById("channelsList");
            list.innerHTML = "";
            const filtered = channelsData.filter(ch => {
                if (currentCategory === "all") return true;
                if (currentCategory === "wiseplay") {
                    if (currentSub === "all") return ch.category === "wiseplay";
                    return ch.category === "wiseplay" && ch.sub === currentSub;
                }
                if (currentCategory === "ทีวีเขมร") {
                    if (currentSubKhmer === "all") return ch.category === "ทีวีเขมร";
                    return ch.category === "ทีวีเขมร" && ch.subkhmer === currentSubKhmer;
                }
                return ch.category === currentCategory;
            });
            filtered.forEach((ch) => {
                const card = document.createElement("div");
                card.className = "channel-card";
                const globalIdx = channelsData.findIndex(c => (c.url && c.url === ch.url) || (c.intent && c.intent === ch.intent));
                if (currentChannelIndex === globalIdx) card.classList.add("active");
                card.onclick = (e) => { e.stopPropagation(); playChannel(ch, globalIdx); };
                card.innerHTML = `
                        <div class="img-container">
                            <img src="${ch.logo}" alt="${ch.name}" onerror="this.src='https://img2.pic.in.th/media.png'">
                            <div class="live-badge">🔴 สด</div>
                        </div>
                        <div class="info-bar"><span>${ch.name}</span></div>
                    `;
                list.appendChild(card);
            });
        }

        function setCategory(cat, btn) {
            currentCategory = cat;
            currentSub = "all";
            currentSubKhmer = "all";
            document.querySelectorAll(".main-category-nav button").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            const subNav = document.getElementById("subCategoryNav");
            const subKhmerNav = document.getElementById("subKhmerNav");
            const wrapper = document.getElementById("videoWrapper");
            const overlay = document.getElementById("playOverlay");
            const banner = document.getElementById("wiseplayBanner");
            const title = document.getElementById("sectionTitle");
            const mainContent = document.getElementById("mainContent");
            const leftPanel = document.getElementById("leftPanel");

            title.textContent = cat === "all" ? "ช่องรายการ" : btn.textContent;

            subNav.classList.remove("active");
            subKhmerNav.classList.remove("active");

            if (cat === "wiseplay") {
                subNav.classList.add("active");
                wrapper.classList.add("wiseplay-mode");
                mainContent.classList.add("wiseplay-mode");
                leftPanel.style.display = "none";
                banner.classList.add("show");
                stopPlayer();
            } else if (cat === "ทีวีเขมร") {
                subKhmerNav.classList.add("active");
                wrapper.classList.remove("wiseplay-mode");
                mainContent.classList.remove("wiseplay-mode");
                leftPanel.style.display = "flex";
                banner.classList.remove("show");
                if (!document.querySelector("#player-container video:not([style*='display: none'])") && !document.querySelector("#player-container #player:not([style*='display: none'])")) {
                    overlay.style.display = "flex";
                }
            } else {
                wrapper.classList.remove("wiseplay-mode");
                mainContent.classList.remove("wiseplay-mode");
                leftPanel.style.display = "flex";
                banner.classList.remove("show");
                if (!document.querySelector("#player-container video:not([style*='display: none'])") && !document.querySelector("#player-container #player:not([style*='display: none'])")) {
                    overlay.style.display = "flex";
                }
                document.querySelectorAll(".sub-category-nav button").forEach(b => b.classList.remove("active"));
                if (subNav.firstElementChild) subNav.firstElementChild.classList.add("active");
            }
            renderChannels();
        }

        function setSubCategory(sub, btn) {
            currentSub = sub;
            document.querySelectorAll("#subCategoryNav button").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            renderChannels();
        }

        function setSubKhmer(sub, btn) {
            currentSubKhmer = sub;
            document.querySelectorAll("#subKhmerNav button").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");
            renderChannels();
        }

        function showToast(msg) {
            const t = document.getElementById("toastMessage");
            t.textContent = msg;
            t.style.opacity = 1;
            setTimeout(() => t.style.opacity = 0, 2500);
        }

        function stopPlayer() {
            try { jwplayer().stop(); } catch (e) {}
            try { nativeVideo.pause(); } catch (e) {}
            nativeVideo.style.display = "none";
            document.getElementById("player").style.display = "block";
            document.getElementById("playOverlay").style.display = "flex";
            if (hlsEngine) { hlsEngine.destroy(); hlsEngine = null; }
        }

        function playChannel(channel, idx, autoPlayMuted = false) {
            if (isChangingChannel) return;
            isChangingChannel = true;
            currentChannelIndex = idx;
            renderChannels();
            const wrapper = document.getElementById("videoWrapper");
            const overlay = document.getElementById("playOverlay");
            const banner = document.getElementById("wiseplayBanner");
            const mainContent = document.getElementById("mainContent");
            const leftPanel = document.getElementById("leftPanel");

            if (channel.category === "wiseplay") {
                wrapper.classList.add("wiseplay-mode");
                mainContent.classList.add("wiseplay-mode");
                leftPanel.style.display = "none";
                banner.classList.add("show");
                stopPlayer();
                if (channel.intent) {
                    showToast("กำลังเปิด Wiseplay..");
                    window.location.href = channel.intent;
                    isChangingChannel = false;
                    return;
                }
            } else {
                wrapper.classList.remove("wiseplay-mode");
                mainContent.classList.remove("wiseplay-mode");
                leftPanel.style.display = "flex";
                banner.classList.remove("show");
            }
            stopPlayer();
            overlay.style.display = "none";
            if (channel.url && channel.url.includes(".mpd")) {
                nativeVideo.style.display = "none";
                document.getElementById("player").style.display = "block";
                let cfg = { file: channel.url, type: "dash", autostart: true, muted: autoPlayMuted, width: "100%", height: "100%" };
                if (channel.keyId && channel.key) cfg.drm = { clearkey: { keyId: channel.keyId, key: channel.key } };
                jwplayer("player").setup(cfg);
            } else if (channel.url) {
                if (Hls.isSupported()) {
                    document.getElementById("player").style.display = "none";
                    nativeVideo.style.display = "block";
                    nativeVideo.muted = autoPlayMuted;
                    hlsEngine = new Hls();
                    hlsEngine.loadSource(channel.url);
                    hlsEngine.attachMedia(nativeVideo);
                    hlsEngine.on(Hls.Events.MANIFEST_PARSED, () => {
                        nativeVideo.play().catch(() => {
                            nativeVideo.muted = false;
                            nativeVideo.play();
                            showToast("👆 คลิกที่หน้าจอเพื่อเปิดเสียง");
                        });
                    });
                } else {
                    nativeVideo.style.display = "none";
                    document.getElementById("player").style.display = "block";
                    jwplayer("player").setup({ file: channel.url, type: "hls", autostart: true, muted: autoPlayMuted, width: "100%", height: "100%" });
                }
            } else {
                showToast("⚠️ ช่องนี้ไม่มีสตรีม");
                overlay.style.display = "flex";
            }
            setTimeout(() => { isChangingChannel = false; }, 1000);
        }

        document.addEventListener('click', function() {
            try { nativeVideo.muted = false; nativeVideo.play().catch(() => {}); } catch (e) {}
            try { jwplayer().setMute(false); } catch (e) {}
        });
        document.addEventListener('touchstart', function() {
            try { nativeVideo.muted = false; nativeVideo.play().catch(() => {}); } catch (e) {}
            try { jwplayer().setMute(false); } catch (e) {}
        });

        window.addEventListener('DOMContentLoaded', () => {
            renderChannels();
            if (channelsData.length > 0) {
                playChannel(channelsData[0], 0, true);
                showToast("");
            }
        });
    </script>

